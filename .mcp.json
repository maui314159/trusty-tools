{
  "mcpServers": {
    "trusty-search": {
      "type": "stdio",
      "command": "trusty-search",
      "args": [
        "serve"
      ]
    },
    "trusty-mpm": {
      "type": "stdio",
      "command": "trusty-mpm",
      "args": [
        "daemon",
        "--mcp"
      ]
    },
    "trusty-memory": {
      "type": "stdio",
      "command": "trusty-memory",
      "args": [
        "serve",
        "--stdio",
        "--palace",
        "trusty-tools"
      ]
    }
  }
}
