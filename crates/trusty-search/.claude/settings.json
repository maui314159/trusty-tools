{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cargo build*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo clippy*)",
      "Bash(cargo run*)",
      "Bash(cargo install*)",
      "Bash(cargo bench*)",
      "Bash(cargo fmt*)",
      "Bash(cargo clean*)",
      "Bash(RUST_LOG=* cargo *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git show*)"
    ]
  }
}
